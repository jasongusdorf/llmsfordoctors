---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Sidebar from '../components/Sidebar.astro';
import NewsSection from '../components/NewsSection.astro';
import { getCollection } from 'astro:content';
import { env } from 'cloudflare:workers';
import type { NewsItem } from '../utils/types';

let newsData: NewsItem[] = [];
try {
  const cached = await env.NEWS_CACHE.get('latest');
  newsData = cached ? JSON.parse(cached) : [];
} catch {
  // Local dev or KV unavailable — fall back to static JSON
  try {
    newsData = (await import('../data/news.json')).default;
  } catch {
    // No news at all — degrade gracefully
  }
}

const allGuides = await getCollection('guides');
const featuredGuides = allGuides
  .filter((g) => g.data.featured && g.id !== 'llms-in-clinical-care-101')
  .sort((a, b) => b.data.lastUpdated.getTime() - a.data.lastUpdated.getTime());
---

<BaseLayout
  title="LLMs for Doctors — AI Workflows for Clinicians"
  description="Practical AI workflows, tools, and templates for clinicians. Evidence-based, privacy-aware, specialty-specific."
>
  <Hero />

  <!-- Featured Guides -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-12">
    <h2 class="font-heading text-2xl font-semibold text-clinical-900 dark:text-clinical-50 mb-6">Featured Guides</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {featuredGuides.map((guide) => (
        <a
          href={`/guides/${guide.id}`}
          class="group block rounded-lg border border-clinical-200 dark:border-clinical-700 bg-white dark:bg-clinical-800 p-6 hover:border-clinical-400 dark:hover:border-clinical-500 hover:shadow-md transition-all"
        >
          <h3 class="font-heading text-lg font-semibold text-clinical-900 dark:text-clinical-50 group-hover:text-clinical-600 dark:group-hover:text-clinical-300 transition-colors mb-2">
            {guide.data.title}
          </h3>
          <p class="text-sm text-clinical-600 dark:text-clinical-400 line-clamp-2 mb-3">
            {guide.data.description}
          </p>
          <span class="text-xs text-clinical-500 dark:text-clinical-500">
            Updated {guide.data.lastUpdated.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </span>
        </a>
      ))}
    </div>
  </div>

  <!-- News Section -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <NewsSection items={newsData} />
  </div>

  <!-- Physician Forum callout -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <a
      href="https://community.llmsfordoctors.com"
      class="group block max-w-2xl mx-auto"
    >
      <div class="relative px-8 py-6 border border-clinical-200 dark:border-clinical-700/50 rounded-sm bg-clinical-50 dark:bg-clinical-800/30 hover:bg-clinical-100 dark:hover:bg-clinical-800/50 hover:border-clinical-300 dark:hover:border-clinical-600/60 transition-all duration-300">
        <!-- Top decorative rule -->
        <div class="absolute top-0 left-8 right-8 h-px bg-gradient-to-r from-transparent via-clinical-300 dark:via-clinical-500/40 to-transparent"></div>

        <!-- Rod of Asclepius icon -->
        <div class="flex items-center justify-center mb-3">
          <svg class="w-5 h-5 text-clinical-400 dark:text-clinical-500 group-hover:text-clinical-600 dark:group-hover:text-clinical-400 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v20M9 5c0-1 1.5-2 3-2s3 1 3 2-1.5 2-3 2-3-1-3-2zM9 9c0-1 1.5-2 3-2s3 1 3 2-1.5 2-3 2-3-1-3-2zM9 13c0-1 1.5-2 3-2s3 1 3 2-1.5 2-3 2-3-1-3-2z" />
          </svg>
        </div>

        <p class="font-display text-xs font-semibold uppercase tracking-[0.3em] text-clinical-500 group-hover:text-clinical-600 dark:group-hover:text-clinical-400 transition-colors mb-2 text-center">
          Physician Forum
        </p>
        <p class="font-display text-xl sm:text-2xl font-medium italic text-clinical-700 dark:text-clinical-200 group-hover:text-clinical-900 dark:group-hover:text-white transition-colors leading-snug text-center">
          Join the conversation with verified colleagues
        </p>
        <p class="font-body text-xs text-clinical-500 mt-3 tracking-wide text-center">
          NPI-verified &ensp;&middot;&ensp; Ad-free &ensp;&middot;&ensp; Physician-moderated
        </p>

        <!-- Bottom decorative rule -->
        <div class="absolute bottom-0 left-8 right-8 h-px bg-gradient-to-r from-transparent via-clinical-300 dark:via-clinical-500/40 to-transparent"></div>
      </div>
    </a>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-10 text-center">
      <h2 class="font-heading text-2xl font-semibold text-clinical-900 dark:text-clinical-50 mb-3">Support This Project</h2>
      <p class="text-clinical-600 dark:text-clinical-300 mb-6">LLMs for Doctors is free, ad-free, and independent. Your donation helps keep it that way.</p>
      <a
        href="/donate"
        class="inline-block px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors"
      >
        Donate
      </a>
    </div>
  </div>
</BaseLayout>
