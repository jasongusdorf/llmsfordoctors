---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TemplateList from '../../components/TemplateList.tsx';

const allTemplates = await getCollection('templates');

const categoryOrder = [
  'note-writing',
  'clinical-reasoning',
  'patient-education',
  'literature-review',
  'admin-billing',
  'board-prep',
];

const templatesData = allTemplates.map((t) => ({
  id: t.id,
  title: t.data.title,
  category: t.data.category,
  targetTool: t.data.targetTool,
  tags: t.data.tags,
  lastUpdated: t.data.lastUpdated.toISOString(),
}));

const presentCategories = categoryOrder.filter((cat) =>
  allTemplates.some((t) => t.data.category === cat),
);

const allTargetTools = [...new Set(allTemplates.map((t) => t.data.targetTool))].sort();
---

<BaseLayout
  title="Prompt Templates - LLMs for Doctors"
  description="Ready-to-use AI prompt templates for clinical documentation, patient communication, and more."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Templates' }]} />

    <header class="mb-10">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-clinical-900 dark:text-clinical-50 mb-3">
        Prompt Templates
      </h1>
      <p class="text-lg text-clinical-600 dark:text-clinical-400">
        Copy-ready prompt templates optimized for clinical use cases.
      </p>
    </header>

    {templatesData.length === 0 ? (
      <div class="text-center py-20 text-clinical-500 dark:text-clinical-400">
        <p class="text-xl font-medium">Templates coming soon.</p>
        <p class="mt-2 text-sm">We're building a library of clinical prompt templates. Check back soon.</p>
      </div>
    ) : (
      <TemplateList
        templates={templatesData}
        categories={presentCategories}
        targetTools={allTargetTools}
        client:load
      />
    )}
  </div>
</BaseLayout>
