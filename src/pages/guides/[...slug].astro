---
import { getCollection, render } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('guides');
  return entries.map((e) => ({ params: { slug: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  lastUpdated={entry.data.lastUpdated}
  tags={entry.data.tags}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Guides', href: '/guides' },
    { label: entry.data.title },
  ]}
>
  {headings.length > 0 && (
    <nav class="mb-8 p-4 rounded-lg bg-clinical-50 dark:bg-clinical-800 border border-clinical-200 dark:border-clinical-700 not-prose">
      <p class="text-xs font-semibold uppercase tracking-wide text-clinical-500 dark:text-clinical-400 mb-2">
        On this page
      </p>
      <ol class="space-y-1">
        {headings.filter((h) => h.depth <= 3).map((h) => (
          <li class={h.depth === 2 ? '' : 'ml-4'}>
            <a
              href={`#${h.slug}`}
              class="text-sm text-blue-600 dark:text-blue-400 hover:underline"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )}
  <Content />
</ContentLayout>
