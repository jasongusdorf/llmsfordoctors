---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Community - LLMs for Doctors"
  description="Join a verified physician community discussing AI in clinical practice. NPI-verified, privacy-focused, specialty-spanning."
>

  <!-- Hero -->
  <section class="bg-clinical-900 py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-blue-400 mb-4">
        Physician-Only Forum
      </p>
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-white mb-6 leading-tight">
        The community for clinicians using AI
      </h1>
      <p class="text-lg text-clinical-300 mb-10 max-w-xl mx-auto">
        Share workflows, troubleshoot prompts, and learn from peers. Every member is NPI-verified. No vendors, no noise.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://auth.llmsfordoctors.com/register"
          class="inline-block px-8 py-3.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-md transition-colors"
        >
          Join Now - Free for Physicians
        </a>
        <a
          href="https://community.llmsfordoctors.com"
          class="inline-block px-8 py-3.5 bg-clinical-800 hover:bg-clinical-700 text-clinical-100 text-sm font-semibold rounded-md border border-clinical-600 transition-colors"
        >
          Browse the Forum
        </a>
      </div>
    </div>
  </section>

  <!-- How Verification Works -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="font-heading text-2xl font-semibold text-clinical-900 dark:text-clinical-50 mb-4 text-center">
      How It Works
    </h2>
    <p class="text-clinical-600 dark:text-clinical-300 text-center mb-12 max-w-2xl mx-auto">
      Three steps to join. Takes under two minutes.
    </p>

    <div class="grid gap-8 sm:grid-cols-3">
      <div class="text-center">
        <div class="w-12 h-12 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center mx-auto mb-4 text-lg font-bold">1</div>
        <h3 class="font-heading font-semibold text-clinical-900 dark:text-clinical-50 mb-2">Enter Your NPI</h3>
        <p class="text-sm text-clinical-600 dark:text-clinical-400">
          We verify your identity against the NPPES national registry in real time. Only individual physician NPIs are accepted.
        </p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center mx-auto mb-4 text-lg font-bold">2</div>
        <h3 class="font-heading font-semibold text-clinical-900 dark:text-clinical-50 mb-2">Create Your Account</h3>
        <p class="text-sm text-clinical-600 dark:text-clinical-400">
          Set your email and password. We send a verification link. No social logins, no third-party data sharing.
        </p>
      </div>
      <div class="text-center">
        <div class="w-12 h-12 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center mx-auto mb-4 text-lg font-bold">3</div>
        <h3 class="font-heading font-semibold text-clinical-900 dark:text-clinical-50 mb-2">Start Discussing</h3>
        <p class="text-sm text-clinical-600 dark:text-clinical-400">
          You are signed into the forum automatically via SSO. Jump into any category and start posting.
        </p>
      </div>
    </div>
  </section>

  <!-- Forum Categories -->
  <section class="bg-clinical-100 dark:bg-clinical-800/50 py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-heading text-2xl font-semibold text-clinical-900 dark:text-clinical-50 mb-4 text-center">
        Forum Categories
      </h2>
      <p class="text-clinical-600 dark:text-clinical-300 text-center mb-12 max-w-2xl mx-auto">
        Organized by the work you actually do.
      </p>

      <div class="grid gap-4 sm:grid-cols-2">
        {[
          {
            title: 'Note Writing & Documentation',
            desc: 'Discharge summaries, progress notes, H&Ps. Share prompts that save time and produce better documentation.',
            color: 'bg-blue-500',
          },
          {
            title: 'Clinical Reasoning',
            desc: 'Differential diagnosis, treatment planning, clinical decision support. How to use AI as a thinking partner.',
            color: 'bg-green-500',
          },
          {
            title: 'Patient Education',
            desc: 'Handouts, discharge instructions, condition explainers. Making patient communication clearer and faster.',
            color: 'bg-purple-500',
          },
          {
            title: 'Literature Review',
            desc: 'Summarizing papers, staying current, journal club prep. Using AI to keep up with the evidence.',
            color: 'bg-amber-500',
          },
          {
            title: 'Admin & Billing',
            desc: 'Prior auth letters, appeals, MDM documentation, coding. The paperwork side of medicine.',
            color: 'bg-red-500',
          },
          {
            title: 'Board Prep & Education',
            desc: 'Study aids, question generation, concept review. AI as a study partner for boards and CME.',
            color: 'bg-teal-500',
          },
          {
            title: 'General Discussion',
            desc: 'New tools, policy changes, career questions, anything else related to AI in medicine.',
            color: 'bg-clinical-500',
          },
        ].map(({ title, desc, color }) => (
          <div class="rounded-lg border border-clinical-200 dark:border-clinical-700 bg-white dark:bg-clinical-800 p-5">
            <div class="flex items-center gap-3 mb-2">
              <div class={`w-3 h-3 rounded-full ${color}`} />
              <h3 class="font-heading font-semibold text-clinical-900 dark:text-clinical-50">{title}</h3>
            </div>
            <p class="text-sm text-clinical-600 dark:text-clinical-400">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust & Safety -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="font-heading text-2xl font-semibold text-clinical-900 dark:text-clinical-50 mb-8 text-center">
      Trust & Safety
    </h2>

    <div class="grid gap-6 sm:grid-cols-2">
      <div class="rounded-lg border border-clinical-200 dark:border-clinical-700 p-6">
        <h3 class="font-heading font-semibold text-clinical-900 dark:text-clinical-50 mb-2">NPI-Verified Only</h3>
        <p class="text-sm text-clinical-600 dark:text-clinical-400">
          Every member is verified against the NPPES national registry. No anonymous accounts, no vendor reps, no bots.
        </p>
      </div>
      <div class="rounded-lg border border-clinical-200 dark:border-clinical-700 p-6">
        <h3 class="font-heading font-semibold text-clinical-900 dark:text-clinical-50 mb-2">No PHI</h3>
        <p class="text-sm text-clinical-600 dark:text-clinical-400">
          Forum rules prohibit sharing patient-identifiable information. Discussions use de-identified examples only.
        </p>
      </div>
      <div class="rounded-lg border border-clinical-200 dark:border-clinical-700 p-6">
        <h3 class="font-heading font-semibold text-clinical-900 dark:text-clinical-50 mb-2">Physician Moderators</h3>
        <p class="text-sm text-clinical-600 dark:text-clinical-400">
          Moderation is handled by active community members who earn trust through participation, not appointment.
        </p>
      </div>
      <div class="rounded-lg border border-clinical-200 dark:border-clinical-700 p-6">
        <h3 class="font-heading font-semibold text-clinical-900 dark:text-clinical-50 mb-2">Ad-Free & Independent</h3>
        <p class="text-sm text-clinical-600 dark:text-clinical-400">
          No sponsored content, no vendor partnerships, no data monetization. Funded by donations.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="bg-clinical-900 rounded-lg p-10 text-center">
      <h2 class="font-heading text-2xl font-semibold text-clinical-50 mb-3">Ready to join?</h2>
      <p class="text-clinical-300 mb-6 max-w-lg mx-auto">
        Registration takes under two minutes. All you need is your NPI number and an email address.
      </p>
      <a
        href="https://auth.llmsfordoctors.com/register"
        class="inline-block px-8 py-3.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-md transition-colors"
      >
        Join Now - Free for Physicians
      </a>
    </div>
  </section>

</BaseLayout>
