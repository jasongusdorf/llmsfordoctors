---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ArticleList from '../../components/ArticleList.tsx';

const allEditorials = await getCollection('editorials');

const editorialsData = allEditorials.map((editorial) => ({
  id: editorial.id,
  title: editorial.data.title,
  description: editorial.data.description,
  tags: editorial.data.tags,
  lastUpdated: editorial.data.lastUpdated.toISOString(),
  featured: editorial.data.featured,
}));

const allTags = [...new Set(allEditorials.flatMap((e) => e.data.tags))].sort();
---

<BaseLayout
  title="Editorials - LLMs for Doctors"
  description="Opinion, analysis, and commentary on AI in clinical medicine."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Editorials' }]} />

    <header class="mb-10">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-clinical-900 dark:text-clinical-50 mb-3">
        Editorials
      </h1>
      <p class="text-lg text-clinical-600 dark:text-clinical-400">
        Analysis, opinion, and commentary on AI in clinical medicine.
      </p>
    </header>

    {editorialsData.length === 0 ? (
      <div class="text-center py-20 text-clinical-500 dark:text-clinical-400">
        <p class="text-xl font-medium">Editorials coming soon.</p>
        <p class="mt-2 text-sm">Check back soon.</p>
      </div>
    ) : (
      <ArticleList articles={editorialsData} basePath="/editorials" tags={allTags} client:load />
    )}
  </div>
</BaseLayout>
