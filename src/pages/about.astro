---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<BaseLayout
  title="About - LLMs for Doctors"
  description="LLMs for Doctors is a resource for clinicians learning to use AI responsibly and effectively in clinical practice."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'About' }]} />

    <!-- Mission -->
    <section class="mb-12">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-clinical-900 dark:text-clinical-50 mb-6">
        About LLMs for Doctors
      </h1>
      <div class="prose prose-clinical dark:prose-invert max-w-none">
        <p class="text-lg leading-relaxed">
          Large language models are transforming clinical practice, but most physicians don't have a trusted, evidence-based resource to help them use these tools well. <strong>LLMs for Doctors</strong> fills that gap.
        </p>
        <p>
          Our mission is to provide clinicians with practical, privacy-aware, and evidence-grounded guidance on integrating AI into everyday clinical work: from documentation and patient communication to clinical reasoning and literature review.
        </p>
        <p>
          Every workflow, tool review, and prompt template here is written by a physician for physicians. We're honest about limitations, rigorous about HIPAA, and focused on what actually works in the clinic.
        </p>
      </div>
    </section>

    <!-- About Jason -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-clinical-900 dark:text-clinical-50 mb-4">
        About Jason Gusdorf, MD
      </h2>
      <div class="flex flex-col sm:flex-row gap-6 items-start">
        <img
          src="/headshot.png"
          alt="Jason Gusdorf, MD"
          class="w-32 h-32 rounded-full object-cover object-[center_15%] border-2 border-clinical-200 dark:border-clinical-600 flex-shrink-0"
        />
        <div class="prose prose-clinical dark:prose-invert max-w-none flex-1">
          <p>
            Jason Gusdorf is a physician who builds software. He created LLMs for Doctors because he kept watching colleagues try AI tools with no reliable guide for what worked, what was safe, and what was marketing. This site is the resource he wished existed when he started.
          </p>
          <p>
            When he's not seeing patients or writing about AI, he's writing code and thinking about how to keep patient data private while still making these tools useful.
          </p>
          <p>
            Learn more at <a href="https://jasongusdorf.com" target="_blank" rel="noopener noreferrer">jasongusdorf.com</a>.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section>
      <h2 class="font-heading text-2xl font-bold text-clinical-900 dark:text-clinical-50 mb-4">
        Get in Touch
      </h2>
      <p class="text-clinical-600 dark:text-clinical-400 mb-6">
        Have a question, suggestion, or want to collaborate? Fill out the form below.
      </p>

      <form
        id="contact-form"
        class="space-y-5"
      >
        <div>
          <label for="name" class="block text-sm font-medium text-clinical-700 dark:text-clinical-300 mb-1">
            Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full rounded-md border border-clinical-300 dark:border-clinical-600 bg-white dark:bg-clinical-800 px-3 py-2 text-clinical-900 dark:text-clinical-100 placeholder-clinical-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm"
            placeholder="Dr. Jane Smith"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-clinical-700 dark:text-clinical-300 mb-1">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full rounded-md border border-clinical-300 dark:border-clinical-600 bg-white dark:bg-clinical-800 px-3 py-2 text-clinical-900 dark:text-clinical-100 placeholder-clinical-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm"
            placeholder="you@example.com"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-clinical-700 dark:text-clinical-300 mb-1">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows={5}
            required
            class="w-full rounded-md border border-clinical-300 dark:border-clinical-600 bg-white dark:bg-clinical-800 px-3 py-2 text-clinical-900 dark:text-clinical-100 placeholder-clinical-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm resize-y"
            placeholder="Your message..."
          ></textarea>
        </div>

        <div class="flex items-center gap-4">
          <button
            type="submit"
            class="px-5 py-2.5 rounded-md bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
          >
            Send Message
          </button>
          <p id="contact-status" class="text-sm hidden"></p>
        </div>
      </form>

      <script>
        document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const form = e.target as HTMLFormElement;
          const name = (form.querySelector('#name') as HTMLInputElement).value;
          const email = (form.querySelector('#email') as HTMLInputElement).value;
          const message = (form.querySelector('#message') as HTMLTextAreaElement).value;
          const status = document.getElementById('contact-status')!;
          const btn = form.querySelector('button')!;
          btn.disabled = true;
          btn.textContent = 'Sending...';
          try {
            const res = await fetch('/api/contact', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ name, email, message }),
            });
            if (res.ok) {
              status.textContent = 'Message sent. Thank you!';
              status.className = 'text-sm text-green-600 dark:text-green-400';
              form.reset();
            } else {
              const data = await res.json();
              status.textContent = data.error || 'Something went wrong.';
              status.className = 'text-sm text-red-600 dark:text-red-400';
            }
          } catch {
            status.textContent = 'Network error. Please try again.';
            status.className = 'text-sm text-red-600 dark:text-red-400';
          }
          btn.disabled = false;
          btn.textContent = 'Send Message';
        });
      </script>
    </section>
  </div>
</BaseLayout>
