---
import NewsCard from './NewsCard.astro';
import type { NewsItem } from '../utils/types';

interface Props {
  items: NewsItem[];
  updatedAt?: string | null;
}

const { items, updatedAt } = Astro.props;
const formattedDate = updatedAt
  ? new Date(updatedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : null;
---

{items.length > 0 && (
  <section>
    <div class="border-t border-clinical-200 dark:border-clinical-700 pt-8 mb-6">
      <h2 class="font-heading text-2xl font-bold text-clinical-900 dark:text-clinical-50">
        Latest AI in Medicine Research
      </h2>
      {formattedDate && (
        <p class="mt-1 text-sm text-clinical-500 dark:text-clinical-400">Updated {formattedDate}</p>
      )}
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {items.map((item) => (
        <NewsCard {...item} />
      ))}
    </div>
  </section>
)}
