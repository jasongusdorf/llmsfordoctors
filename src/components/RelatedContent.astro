---
interface RelatedItem {
  title: string;
  href: string;
  type: 'workflow' | 'guide' | 'tool' | 'template' | 'trial';
}

interface Props {
  items: RelatedItem[];
}

const { items } = Astro.props;

const typeColors: Record<RelatedItem['type'], string> = {
  workflow: 'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300',
  guide: 'bg-purple-100 text-purple-700 dark:bg-purple-900 dark:text-purple-300',
  tool: 'bg-amber-100 text-amber-700 dark:bg-amber-900 dark:text-amber-300',
  template: 'bg-violet-100 text-violet-700 dark:bg-violet-900 dark:text-violet-300',
  trial: 'bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300',
};
---

{items.length > 0 && (
  <section class="mt-10 pt-8 border-t border-clinical-200 dark:border-clinical-700">
    <h2 class="text-lg font-semibold text-clinical-800 dark:text-clinical-100 mb-4">Related Content</h2>
    <ul class="space-y-2">
      {items.map((item) => (
        <li class="flex items-center gap-3">
          <span class={`px-2 py-0.5 rounded text-xs font-semibold capitalize shrink-0 ${typeColors[item.type]}`}>
            {item.type}
          </span>
          <a
            href={item.href}
            class="text-clinical-700 dark:text-clinical-300 hover:text-blue-600 dark:hover:text-blue-400 hover:underline underline-offset-2"
          >
            {item.title}
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
