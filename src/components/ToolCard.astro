---
interface Props {
  name: string;
  slug: string;
  rating: number;
  verdict: string;
  hasBaa: boolean;
}

const { name, slug, rating, verdict, hasBaa } = Astro.props;

// Clamp to 0–5 (0 = warning state)
const stars = Math.min(5, Math.max(0, Math.round(rating)));
---

<a
  href={`/tools/${slug}`}
  class:list={[
    'block rounded-lg border bg-warm-white dark:bg-clinical-800 p-5 hover:shadow-md transition-all',
    stars === 0
      ? 'border-red-400 dark:border-red-600 border-l-4 border-l-red-500'
      : 'border-clinical-200 dark:border-clinical-700 hover:border-clinical-400 dark:hover:border-clinical-500',
  ]}
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-heading font-semibold text-clinical-900 dark:text-clinical-50 leading-snug">{name}</h3>
    {hasBaa && (
      <span class="shrink-0 inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-callout-evidence-bg text-callout-evidence-text border border-callout-evidence-border whitespace-nowrap">
        BAA Available
      </span>
    )}
  </div>

  <!-- Star rating -->
  <div class="mt-2 flex items-center gap-0.5" aria-label={`Rating: ${rating} out of 5`}>
    {Array.from({ length: 5 }, (_, i) => (
      <svg
        class:list={['w-4 h-4', i < stars ? 'text-amber-400' : 'text-clinical-300 dark:text-clinical-600']}
        fill="currentColor"
        viewBox="0 0 20 20"
        aria-hidden="true"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    ))}
    <span class="ml-1 text-xs text-clinical-500 dark:text-clinical-400">{rating.toFixed(1)}</span>
  </div>

  <!-- Verdict -->
  <p class="mt-2 text-sm text-clinical-600 dark:text-clinical-400 line-clamp-2">{verdict}</p>
</a>
