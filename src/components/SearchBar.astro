---
// Custom search using the Pagefind JS API directly.
// Replaces the default Pagefind UI with a styled component that matches the hero.
---

<div class="relative w-full" id="search-container">
  <div class="relative">
    <svg
      class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-clinical-400 pointer-events-none"
      fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.2-5.2m0 0A7.5 7.5 0 105.8 5.8a7.5 7.5 0 0010 10z" />
    </svg>
    <input
      id="search-input"
      type="search"
      placeholder="Search guides, tools, trials..."
      autocomplete="off"
      class="w-full pl-11 pr-10 py-3 rounded-lg bg-warm-white/60 dark:bg-clinical-800/50 backdrop-blur-xl border border-clinical-200 dark:border-clinical-600/25 text-clinical-800 dark:text-clinical-100 placeholder-clinical-400 text-sm font-body focus:outline-none focus:border-clinical-400 dark:focus:border-clinical-500/50 focus:ring-1 focus:ring-clinical-300 dark:focus:ring-clinical-500/30 transition-all"
    />
    <button
      id="search-clear"
      class="absolute right-3 top-1/2 -translate-y-1/2 text-clinical-500 hover:text-clinical-300 transition-colors hidden"
      aria-label="Clear search"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div
    id="search-results"
    class="absolute left-0 right-0 top-full mt-2 rounded-lg bg-clinical-900/95 backdrop-blur-xl border border-clinical-700/50 shadow-2xl overflow-hidden hidden z-50 max-h-[60vh] overflow-y-auto"
  >
    <div id="search-results-list"></div>
    <div id="search-empty" class="hidden px-4 py-6 text-center text-sm text-clinical-400">
      No results found.
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var input = document.getElementById('search-input');
    var clear = document.getElementById('search-clear');
    var results = document.getElementById('search-results');
    var list = document.getElementById('search-results-list');
    var empty = document.getElementById('search-empty');
    var container = document.getElementById('search-container');
    var pagefind = null;
    var debounceTimer = null;

    function createResultLink(data) {
      var a = document.createElement('a');
      a.href = data.url;
      a.className = 'block px-4 py-3 hover:bg-clinical-800/80 transition-colors border-b border-clinical-800 last:border-0';

      var title = document.createElement('p');
      title.className = 'text-sm font-medium text-clinical-100 leading-snug mb-0.5';
      title.textContent = data.meta.title;

      var excerpt = document.createElement('p');
      excerpt.className = 'text-xs text-clinical-400 line-clamp-1';
      excerpt.textContent = data.excerpt.replace(/<[^>]*>/g, '');

      a.appendChild(title);
      a.appendChild(excerpt);
      return a;
    }

    async function loadPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import('/pagefind/pagefind.js');
        await pagefind.init();
        return pagefind;
      } catch (e) {
        return null;
      }
    }

    async function doSearch(query) {
      if (!query || query.length < 2) {
        results.classList.add('hidden');
        return;
      }

      var pf = await loadPagefind();
      if (!pf) {
        empty.textContent = 'Search available after build.';
        empty.classList.remove('hidden');
        list.replaceChildren();
        results.classList.remove('hidden');
        return;
      }

      var search = await pf.search(query);
      var items = search.results.slice(0, 6);

      if (items.length === 0) {
        empty.textContent = 'No results found.';
        empty.classList.remove('hidden');
        list.replaceChildren();
        results.classList.remove('hidden');
        return;
      }

      empty.classList.add('hidden');
      var fragment = document.createDocumentFragment();

      for (var i = 0; i < items.length; i++) {
        var data = await items[i].data();
        fragment.appendChild(createResultLink(data));
      }

      if (search.results.length > 6) {
        var count = document.createElement('div');
        count.className = 'px-4 py-2 text-xs text-clinical-500 text-center border-t border-clinical-800';
        count.textContent = search.results.length + ' results total';
        fragment.appendChild(count);
      }

      list.replaceChildren(fragment);
      results.classList.remove('hidden');
    }

    input.addEventListener('focus', function () {
      loadPagefind();
    });

    input.addEventListener('input', function () {
      var q = input.value.trim();
      clear.classList.toggle('hidden', !q);
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function () { doSearch(q); }, 200);
    });

    clear.addEventListener('click', function () {
      input.value = '';
      clear.classList.add('hidden');
      results.classList.add('hidden');
      list.replaceChildren();
      input.focus();
    });

    document.addEventListener('click', function (e) {
      if (!container.contains(e.target)) {
        results.classList.add('hidden');
      }
    });

    input.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        results.classList.add('hidden');
        input.blur();
      }
    });
  })();
</script>
