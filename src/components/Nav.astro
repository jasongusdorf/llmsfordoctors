---
import DarkModeToggle from './DarkModeToggle.astro';

const pathname = Astro.url.pathname;

interface NavItem {
  href: string;
  label: string;
}

interface NavGroup {
  label: string;
  items: NavItem[];
}

type NavEntry = NavItem | NavGroup;

function isGroup(entry: NavEntry): entry is NavGroup {
  return 'items' in entry;
}

function isActive(entry: NavEntry): boolean {
  if (isGroup(entry)) {
    return entry.items.some(item => pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href)));
  }
  return pathname === entry.href || (entry.href !== '/' && pathname.startsWith(entry.href));
}

const nav: NavEntry[] = [
  { href: '/', label: 'Home' },
  {
    label: 'Learn',
    items: [
      { href: '/guides',     label: 'Guides' },
      { href: '/editorials', label: 'Editorials' },
      { href: '/trials',     label: 'Trials' },
      { href: '/videos',     label: 'Videos' },
    ],
  },
  {
    label: 'Use',
    items: [
      { href: '/workflows',  label: 'Workflows' },
      { href: '/templates',  label: 'Templates' },
      { href: '/tools',      label: 'Tools' },
    ],
  },
  { href: '/community', label: 'Community' },
  {
    label: 'About',
    items: [
      { href: '/about',   label: 'About the Creator' },
      { href: '/terms',   label: 'Terms of Service' },
      { href: '/privacy', label: 'Privacy Policy' },
    ],
  },
  { href: '/donate',    label: 'Donate' },
];

// Flat list for mobile menu
const allLinks: NavItem[] = nav.flatMap(entry => isGroup(entry) ? entry.items : [entry]);
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-clinical-50/95 dark:bg-clinical-900/95 backdrop-blur border-b border-clinical-200 dark:border-clinical-700">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Brand -->
      <a
        href="/"
        class="flex flex-col hover:opacity-80 transition-opacity"
      >
        <span class="font-heading font-semibold text-lg text-clinical-900 dark:text-clinical-50 leading-tight">
          LLMs for Doctors
        </span>
        <span class="hidden md:block font-display text-xs italic text-clinical-400 dark:text-clinical-500 leading-tight">
          by clinicians, for clinicians
        </span>
      </a>

      <!-- Desktop links -->
      <div class="hidden sm:flex items-center gap-1">
        {nav.map((entry) => (
          isGroup(entry) ? (
            <div class="relative group">
              <button
                class:list={[
                  'px-3 py-2 rounded-md text-sm font-medium transition-colors inline-flex items-center gap-1',
                  isActive(entry)
                    ? 'bg-clinical-100 dark:bg-clinical-800 text-clinical-900 dark:text-clinical-50'
                    : 'text-clinical-600 dark:text-clinical-400 hover:text-clinical-900 dark:hover:text-clinical-100 hover:bg-clinical-100 dark:hover:bg-clinical-800',
                ]}
              >
                {entry.label}
                <svg class="w-3.5 h-3.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="absolute left-0 top-full pt-1 hidden group-hover:block">
                <div class="bg-white dark:bg-clinical-800 border border-clinical-200 dark:border-clinical-700 rounded-lg shadow-lg py-1 min-w-[160px]">
                  {entry.items.map(({ href, label }) => (
                    <a
                      href={href}
                      class:list={[
                        'block px-4 py-2 text-sm transition-colors',
                        pathname === href || pathname.startsWith(href)
                          ? 'bg-clinical-100 dark:bg-clinical-700 text-clinical-900 dark:text-clinical-50 font-medium'
                          : 'text-clinical-600 dark:text-clinical-400 hover:text-clinical-900 dark:hover:text-clinical-100 hover:bg-clinical-50 dark:hover:bg-clinical-700',
                      ]}
                    >
                      {label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={entry.href}
              class:list={[
                'px-3 py-2 rounded-md text-sm font-medium transition-colors',
                isActive(entry)
                  ? 'bg-clinical-100 dark:bg-clinical-800 text-clinical-900 dark:text-clinical-50'
                  : 'text-clinical-600 dark:text-clinical-400 hover:text-clinical-900 dark:hover:text-clinical-100 hover:bg-clinical-100 dark:hover:bg-clinical-800',
              ]}
            >
              {entry.label}
            </a>
          )
        ))}
        <div class="ml-2">
          <DarkModeToggle />
        </div>
      </div>

      <!-- Mobile: dark toggle + hamburger -->
      <div class="flex sm:hidden items-center gap-2">
        <DarkModeToggle />
        <button
          id="mobile-menu-toggle"
          class="p-2 rounded-md text-clinical-600 dark:text-clinical-400 hover:text-clinical-900 dark:hover:text-clinical-100 hover:bg-clinical-100 dark:hover:bg-clinical-800 transition-colors"
          aria-label="Toggle mobile menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile menu (hidden by default) -->
  <div
    id="mobile-menu"
    class="hidden sm:hidden border-t border-clinical-200 dark:border-clinical-700 bg-clinical-50 dark:bg-clinical-900"
  >
    <div class="px-4 py-3 space-y-1">
      {nav.map((entry) => (
        isGroup(entry) ? (
          <>
            <p class="px-3 pt-3 pb-1 text-xs font-semibold uppercase tracking-wider text-clinical-400 dark:text-clinical-500">
              {entry.label}
            </p>
            {entry.items.map(({ href, label }) => (
              <a
                href={href}
                class:list={[
                  'block px-3 py-2 rounded-md text-sm font-medium transition-colors pl-6',
                  pathname === href || pathname.startsWith(href)
                    ? 'bg-clinical-100 dark:bg-clinical-800 text-clinical-900 dark:text-clinical-50'
                    : 'text-clinical-600 dark:text-clinical-400 hover:text-clinical-900 dark:hover:text-clinical-100 hover:bg-clinical-100 dark:hover:bg-clinical-800',
                ]}
              >
                {label}
              </a>
            ))}
          </>
        ) : (
          <a
            href={entry.href}
            class:list={[
              'block px-3 py-2 rounded-md text-sm font-medium transition-colors',
              isActive(entry)
                ? 'bg-clinical-100 dark:bg-clinical-800 text-clinical-900 dark:text-clinical-50'
                : 'text-clinical-600 dark:text-clinical-400 hover:text-clinical-900 dark:hover:text-clinical-100 hover:bg-clinical-100 dark:hover:bg-clinical-800',
            ]}
          >
            {entry.label}
          </a>
        )
      ))}
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>
