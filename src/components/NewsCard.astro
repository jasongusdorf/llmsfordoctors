---
interface Props {
  title: string;
  source: string;
  url: string;
  date: string;
  summary: string;
  imageUrl?: string;
}

const { title, source, url, date, summary } = Astro.props;

function formatDate(isoDate: string): string {
  const d = new Date(isoDate);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<a
  href={url}
  target="_blank"
  rel="noopener"
  class="group block rounded-xl border border-clinical-200 dark:border-clinical-700 bg-amber-50 dark:bg-amber-950/30 overflow-hidden hover:border-blue-400 dark:hover:border-blue-500 hover:shadow-md transition-all"
>
  <!-- Content -->
  <div class="p-4">
    <h3 class="font-heading font-semibold text-sm text-clinical-900 dark:text-clinical-50 leading-snug line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
      {title}
    </h3>
    <p class="mt-1 text-xs text-clinical-500 dark:text-clinical-400">
      {source} &middot; {formatDate(date)}
    </p>
    <p class="mt-2 text-xs text-clinical-600 dark:text-clinical-400 line-clamp-2">
      {summary}
    </p>
  </div>
</a>
