---
interface Props {
  title: string;
  source: string;
  url: string;
  date: string;
  summary: string;
  imageUrl?: string;
}

const { title, source, url, date, summary } = Astro.props;

function formatDate(isoDate: string): string {
  const d = new Date(isoDate);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const sourceColors: Record<string, string> = {
  'NPJ Digital Medicine': 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400',
  'JAMA Network Open': 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-400',
  'Nature Medicine': 'bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-400',
  'Lancet Digital Health': 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-400',
  'Radiology': 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-400',
  'BMJ': 'bg-sky-100 text-sky-700 dark:bg-sky-900/40 dark:text-sky-400',
  'NEJM AI': 'bg-rose-100 text-rose-700 dark:bg-rose-900/40 dark:text-rose-400',
};
const pillColor = sourceColors[source] || 'bg-clinical-100 text-clinical-600 dark:bg-clinical-800 dark:text-clinical-400';
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex flex-col rounded-lg border border-clinical-200 dark:border-clinical-700 bg-white dark:bg-clinical-800 overflow-hidden hover:border-clinical-300 dark:hover:border-clinical-600 hover:shadow-lg transition-all duration-200"
>
  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-center gap-2 mb-3">
      <span class:list={['inline-block px-2 py-0.5 rounded text-[11px] font-medium leading-tight', pillColor]}>
        {source}
      </span>
      <span class="text-[11px] text-clinical-400 dark:text-clinical-500">{formatDate(date)}</span>
    </div>
    <h3 class="font-heading font-semibold text-[15px] text-clinical-900 dark:text-clinical-50 leading-snug line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
      {title}
    </h3>
    <p class="mt-2 text-xs text-clinical-500 dark:text-clinical-400 line-clamp-2 flex-1">
      {summary}
    </p>
    <div class="mt-3 text-xs font-medium text-blue-600 dark:text-blue-400 opacity-0 group-hover:opacity-100 transition-opacity">
      Read article &rarr;
    </div>
  </div>
</a>
