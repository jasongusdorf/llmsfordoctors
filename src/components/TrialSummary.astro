---
interface Props {
  title: string;
  slug: string;
  journal: string;
  year: number;
  keyFinding: string;
}

const { title, slug, journal, year, keyFinding } = Astro.props;
---

<a
  href={`/trials/${slug}`}
  class="block rounded-lg border border-clinical-200 dark:border-clinical-700 bg-warm-white dark:bg-clinical-800 p-5 hover:border-clinical-400 dark:hover:border-clinical-500 hover:shadow-md transition-all"
>
  <!-- Year + journal -->
  <div class="flex items-center gap-2 mb-2">
    <span class="text-xs font-semibold text-clinical-500 dark:text-clinical-400 tabular-nums">{year}</span>
    <span class="text-clinical-300 dark:text-clinical-600" aria-hidden="true">·</span>
    <span class="text-xs text-clinical-500 dark:text-clinical-400 italic truncate">{journal}</span>
  </div>

  <!-- Title -->
  <h3 class="font-heading font-semibold text-clinical-900 dark:text-clinical-50 leading-snug line-clamp-2">
    {title}
  </h3>

  <!-- Key finding -->
  <div class="mt-3 flex items-start gap-2">
    <span class="mt-0.5 shrink-0 w-1 h-1 rounded-full bg-callout-evidence-border mt-1.5" aria-hidden="true"></span>
    <p class="text-sm text-clinical-600 dark:text-clinical-400 line-clamp-3">
      {keyFinding}
    </p>
  </div>
</a>
