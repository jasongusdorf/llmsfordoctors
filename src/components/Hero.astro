---
import SearchBar from './SearchBar.astro';
---

<section class="bg-clinical-900 dark:bg-clinical-900 py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-sm font-semibold uppercase tracking-widest text-blue-400 mb-4">
      LLMs for Doctors
    </p>

    <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
      Make your clinical life easier with AI
    </h1>

    <p class="text-lg text-clinical-300 mb-10 max-w-xl mx-auto">
      Evidence-based workflows, tool reviews, and ready-to-use prompts — built by clinicians, for clinicians. Privacy-aware and specialty-specific.
    </p>

    <div class="max-w-xl mx-auto">
      <SearchBar />
    </div>
  </div>
</section>
