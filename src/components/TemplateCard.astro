---
interface Props {
  title: string;
  slug: string;
  targetTool: string;
  preview: string;
}

const { title, slug, targetTool, preview } = Astro.props;

const cardId = `template-copy-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="rounded-lg border border-clinical-200 dark:border-clinical-700 bg-white dark:bg-clinical-800 overflow-hidden">

  <!-- Card header -->
  <div class="flex items-center justify-between gap-3 px-5 py-4 border-b border-clinical-100 dark:border-clinical-700">
    <div class="flex items-center gap-2 min-w-0">
      <a
        href={`/templates/${slug}`}
        class="font-heading font-semibold text-clinical-900 dark:text-clinical-50 hover:text-clinical-600 dark:hover:text-clinical-300 transition-colors truncate"
      >
        {title}
      </a>
      <span class="shrink-0 inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-clinical-100 dark:bg-clinical-700 text-clinical-600 dark:text-clinical-300 whitespace-nowrap">
        {targetTool}
      </span>
    </div>
    <button
      class="template-copy-btn shrink-0 flex items-center gap-1.5 px-3 py-1 rounded-md text-xs font-medium bg-clinical-50 dark:bg-clinical-900 border border-clinical-300 dark:border-clinical-600 text-clinical-700 dark:text-clinical-300 hover:bg-clinical-100 dark:hover:bg-clinical-800 transition-colors"
      data-copy-target={cardId}
      aria-label={`Copy ${title} template`}
    >
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
      </svg>
      <span class="copy-label">Copy</span>
    </button>
  </div>

  <!-- Preview text -->
  <div
    id={cardId}
    class="px-5 py-4 text-sm text-clinical-600 dark:text-clinical-400 font-mono leading-relaxed line-clamp-4 whitespace-pre-wrap"
  >{preview}</div>

</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.template-copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.dataset.copyTarget;
      if (!targetId) return;
      const el = document.getElementById(targetId);
      if (!el) return;
      const text = el.textContent ?? '';
      try {
        await navigator.clipboard.writeText(text);
        const label = btn.querySelector<HTMLElement>('.copy-label');
        if (label) {
          label.textContent = 'Copied!';
          setTimeout(() => { label.textContent = 'Copy'; }, 2000);
        }
      } catch {
        // Clipboard API unavailable — silent fail
      }
    });
  });
</script>
