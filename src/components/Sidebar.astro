---
import { getLatestGuides, getLatestTools } from '../utils/collections';

const latestGuides = await getLatestGuides(3);
const latestTools = await getLatestTools(3);
---

<aside class="space-y-8">
  <!-- Latest Guides -->
  <section>
    <h2 class="font-heading text-lg font-bold text-clinical-900 dark:text-clinical-50 mb-4 pb-2 border-b border-clinical-200 dark:border-clinical-700">
      Latest Guides
    </h2>
    {latestGuides.length === 0 ? (
      <p class="text-sm text-clinical-400 italic">Coming soon</p>
    ) : (
      <ul class="space-y-3">
        {latestGuides.map((guide) => (
          <li>
            <a
              href={`/guides/${guide.id}`}
              class="text-sm font-medium text-clinical-700 dark:text-clinical-300 hover:text-blue-600 dark:hover:text-blue-400 hover:underline underline-offset-2 block leading-snug"
            >
              {guide.data.title}
            </a>
            <time
              datetime={guide.data.lastUpdated.toISOString()}
              class="text-xs text-clinical-400 mt-0.5 block"
            >
              {guide.data.lastUpdated.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
            </time>
          </li>
        ))}
      </ul>
    )}
    <a href="/guides" class="mt-4 inline-block text-xs text-blue-600 dark:text-blue-400 hover:underline">
      All guides →
    </a>
  </section>

  <!-- Latest Tool Reviews -->
  <section>
    <h2 class="font-heading text-lg font-bold text-clinical-900 dark:text-clinical-50 mb-4 pb-2 border-b border-clinical-200 dark:border-clinical-700">
      Latest Tool Reviews
    </h2>
    {latestTools.length === 0 ? (
      <p class="text-sm text-clinical-400 italic">Coming soon</p>
    ) : (
      <ul class="space-y-3">
        {latestTools.map((tool) => (
          <li class="flex items-start justify-between gap-2">
            <a
              href={`/tools/${tool.id}`}
              class="text-sm font-medium text-clinical-700 dark:text-clinical-300 hover:text-blue-600 dark:hover:text-blue-400 hover:underline underline-offset-2 leading-snug"
            >
              {tool.data.title}
            </a>
            <span class="text-xs text-amber-500 shrink-0 mt-0.5" aria-label={`${tool.data.rating} stars`}>
              {'★'.repeat(Math.round(tool.data.rating))}
            </span>
          </li>
        ))}
      </ul>
    )}
    <a href="/tools" class="mt-4 inline-block text-xs text-blue-600 dark:text-blue-400 hover:underline">
      All tools →
    </a>
  </section>
</aside>
